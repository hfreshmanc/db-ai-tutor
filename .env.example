# ========== 对话（必需）==========
DASHSCOPE_API_KEY=
# 默认 qwen3.6-plus；纯文本模型可改为 qwen-plus
QWEN_MODEL=qwen3.6-plus
# 一般无需手动设置，后端会按模型自动选择 text / multimodal 接口
# DASHSCOPE_API_URL=

# ========== RAG（启用知识库时必需）==========
JINA_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
JINA_EMBEDDING_MODEL=jina-embeddings-v3
# 须与 Pinecone 建索引时的 dimension 一致
JINA_EMBEDDING_DIMENSIONS=768

# ========== Parent-Child 切块（默认 parent_child）==========
# RAG_CHUNK_STRATEGY=parent_child
# RAG_PARENT_SIZE=1000
# RAG_PARENT_OVERLAP=200
# RAG_CHILD_SIZE=250
# RAG_CHILD_OVERLAP=50
# 回退为旧版固定长度切块：RAG_CHUNK_STRATEGY=fixed
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=80

# ========== RAG 调参（可选）==========
# RAG_TOP_K=3
# JINA_EMBED_BATCH=64
# JINA_HTTP_TIMEOUT_SECONDS=300
# JINA_TASK_PASSAGE=retrieval.passage
# JINA_TASK_QUERY=retrieval.query

# ========== 开发环境（可选）==========
# DEV_API_PROXY_TARGET=http://127.0.0.1:3001
# DEV_API_PROXY_TIMEOUT_MS=900000
# DISABLE_HMR=true
